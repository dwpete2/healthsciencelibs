<body>
  <div class="container">
    <header class="card">
      <div>
        <h1>Frequency of Minimum Salaries (Histogram)</h1>
        <div class="sub">
          Uses <b>Salary_Minimum</b> (and if present, <b>Salary_Minimum_II</b> as an alternate min) from <b>2025DataAITest.xlsx</b> Sheet1 (125 rows, 12 columns).[^1]
        </div>
      </div>
      <div class="pill" id="datasetPill"><span class="dot"></span> Ready</div>
    </header>

    <section class="layout">
      <main class="card">
        <div class="card-header">
          <h2>Histogram</h2>
          <div class="pill"><span class="kbd">Hover</span> bin details</div>
        </div>
        <div class="card-body">
          <div class="metrics">
            <div class="metric">
              <div class="k"><span>Count</span><span class="mini">min values used</span></div>
              <div class="v" id="mCount">0</div>
            </div>
            <div class="metric">
              <div class="k"><span>Median</span><span class="mini">min salary</span></div>
              <div class="v" id="mMedian">$0</div>
            </div>
            <div class="metric">
              <div class="k"><span>Min</span><span class="mini">lowest min</span></div>
              <div class="v" id="mMin">$0</div>
            </div>
            <div class="metric">
              <div class="k"><span>Max</span><span class="mini">highest min</span></div>
              <div class="v" id="mMax">$0</div>
            </div>
          </div>

